# Runtime environment. Development enables verbose errors; production hides them.
NODE_ENV=development

# HTTP port for local dev; ignored on Vercel.
PORT=3000

# MongoDB connection string. Atlas or a local replica set (transactions require replica set).
MONGODB_URI=mongodb://localhost:27017/shop-traders

# Comma-separated allowlist of browser origins. Empty disables cross-origin requests.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# When 'true', the API calls Model.syncIndexes() on every registered model at boot.
# Enable in dev/CI; disable in production and run `pnpm --filter @shop/api sync-indexes` from a deploy job.
SYNC_INDEXES=true

# 32+ character secrets. Rotate together and expect all sessions to invalidate.
JWT_SECRET=change-me-to-a-32-character-secret-value
COOKIE_SECRET=change-me-to-a-32-character-cookie-secret

# Token TTLs. Access tokens are short; refresh tokens rotate.
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
