# Runtime environment. Development enables verbose errors; production hides them.
NODE_ENV=development

# HTTP port for local dev; ignored on Vercel.
PORT=3000

# MongoDB connection string. Atlas or a local replica set (transactions require replica set).
MONGODB_URI=mongodb://localhost:27017/shop-traders

# Comma-separated allowlist of browser origins. Empty disables cross-origin requests.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
